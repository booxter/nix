          "range": true,
          "refId": "A"
        },
        {
          "datasource": "Prometheus",
          "editorMode": "code",
          "expr": "100 * (1 - node_memory_MemAvailable_bytes{job=\"node-mtls\",instance=\"home\"} / node_memory_MemTotal_bytes{job=\"node-mtls\",instance=\"home\"})",
          "legendFormat": "Memory",
          "range": true,
          "refId": "B"
