        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "editorMode": "code",
          "expr": "100 * (1 - avg by(instance) (rate(node_cpu_seconds_total{job=\"node-mtls\",instance=\"home\",mode=\"idle\"}[5m])))",
