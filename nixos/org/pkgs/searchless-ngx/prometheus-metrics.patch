+metrics_collection_success = Gauge("searchless_metrics_collection_success", "Whether the most recent Searchless metrics collection completed successfully.")
+paperless_connected = Gauge("searchless_paperless_connected", "Whether Searchless can query the Paperless API.")
+vector_store_initialized = Gauge("searchless_vector_store_initialized", "Whether Searchless can initialize the Chroma vector store.")
+paperless_documents = Gauge("searchless_paperless_documents", "Number of documents visible to Searchless in Paperless.")
+chroma_chunks = Gauge("searchless_chroma_chunks", "Number of chunks stored in Chroma for Searchless retrieval.")
+bulk_sync_limit = Gauge("searchless_bulk_sync_limit", "Configured bulk sync document limit. Zero means unlimited.")
+
