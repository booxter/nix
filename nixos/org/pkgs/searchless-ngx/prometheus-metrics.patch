+async def _collect_metrics():
+    metrics_collection_success.set(1)
+    bulk_sync_limit.set(settings.bulk_sync_limit or 0)
+
+    client = PaperlessAPIClient()
+    try:
+        response = await client.get_documents(params={"page_size": 1})
+        paperless_connected.set(1 if "results" in response else 0)
+        paperless_documents.set(response.get("count", 0))
+    except Exception as e:
+        metrics_collection_success.set(0)
+        paperless_connected.set(0)
+        paperless_documents.set(0)
+        logger.error(f"Metrics Paperless check failed: {e}")
+    finally:
+        await client.close()
+
+    try:
+        from semantic.vector_store import vector_store
+        vector_store._ensure_initialized()
+        if vector_store.collection is None:
+            vector_store_initialized.set(0)
+            chroma_chunks.set(0)
+        else:
+            vector_store_initialized.set(1)
+            chroma_chunks.set(vector_store.collection.count())
+    except Exception as e:
+        metrics_collection_success.set(0)
+        vector_store_initialized.set(0)
+        chroma_chunks.set(0)
+        logger.error(f"Metrics Chroma check failed: {e}")
+
