diff --git a/shelfmark/download/poll_debug.py b/shelfmark/download/poll_debug.py
new file mode 100644
index 0000000..fe271e4
--- /dev/null
+++ b/shelfmark/download/poll_debug.py
@@ -0,0 +1,126 @@
+"""Diagnostic state for external download-client polling."""
+
+from __future__ import annotations
+
+import time
+from threading import Lock
+from typing import Any
+
+_poll_debug_lock = Lock()
+_poll_debug_state: dict[str, dict[str, Any]] = {}
+
+
+def _coerce_float(value: object) -> float | None:
+    if isinstance(value, bool):
+        return None
+    if isinstance(value, (int, float)):
+        return float(value)
+    return None
+
+
+def _stringify(value: object) -> str | None:
+    if value is None:
+        return None
+    if hasattr(value, "value"):
+        enum_value = getattr(value, "value")
+        return str(enum_value)
+    return str(value)
+
+
+def _copy_with_ages(entry: dict[str, Any], now: float) -> dict[str, Any]:
+    copied = dict(entry)
+    for key in (
+        "created_at",
+        "last_poll_started_at",
+        "last_poll_finished_at",
+        "last_poll_error_at",
+    ):
+        timestamp = copied.get(key)
+        if isinstance(timestamp, (int, float)):
+            copied[f"{key}_age_seconds"] = round(now - timestamp, 3)
+    return copied
+
+
+def record_poll_start(
+    *,
+    task_id: str,
+    client_name: str,
+    download_id: str,
+    content_type: str | None,
+) -> None:
+    """Record that a download-client poll is about to run."""
+    now = time.time()
+    with _poll_debug_lock:
+        entry = _poll_debug_state.setdefault(
+            task_id,
+            {
+                "task_id": task_id,
+                "created_at": now,
+                "poll_count": 0,
+            },
+        )
+        entry.update(
+            {
+                "task_id": task_id,
+                "client": client_name,
+                "download_id": download_id,
+                "content_type": content_type,
+                "last_poll_started_at": now,
+                "poll_in_flight": True,
+            }
+        )
+        entry["poll_count"] = int(entry.get("poll_count") or 0) + 1
+        entry.pop("last_error", None)
+
+
+def record_poll_result(task_id: str, status: object) -> None:
+    """Record the result returned by a download-client poll."""
+    now = time.time()
+    with _poll_debug_lock:
+        entry = _poll_debug_state.setdefault(
+            task_id,
+            {
+                "task_id": task_id,
+                "created_at": now,
+                "poll_count": 0,
+            },
+        )
+        entry.update(
+            {
+                "last_poll_finished_at": now,
+                "poll_in_flight": False,
+                "last_progress": _coerce_float(getattr(status, "progress", None)),
+                "last_state": _stringify(getattr(status, "state", None)),
+                "last_message": _stringify(getattr(status, "message", None)),
+                "last_complete": bool(getattr(status, "complete", False)),
+                "last_download_speed": _coerce_float(getattr(status, "download_speed", None)),
+                "last_eta": getattr(status, "eta", None),
+            }
+        )
+
+
+def record_poll_error(task_id: str, error: BaseException) -> None:
+    """Record that a download-client poll raised."""
+    now = time.time()
+    with _poll_debug_lock:
+        entry = _poll_debug_state.setdefault(task_id, {"task_id": task_id, "created_at": now})
+        entry.update(
+            {
+                "last_poll_error_at": now,
+                "poll_in_flight": False,
+                "last_error": f"{type(error).__name__}: {error}",
+            }
+        )
+
+
+def clear_poll_debug_state(task_id: str) -> None:
+    """Drop diagnostic state for a task after its polling function exits."""
+    with _poll_debug_lock:
+        _poll_debug_state.pop(task_id, None)
+
+
+def get_poll_debug_snapshot() -> list[dict[str, Any]]:
+    """Return a snapshot of active poll diagnostics."""
+    now = time.time()
+    with _poll_debug_lock:
+        return [_copy_with_ages(entry, now) for entry in _poll_debug_state.values()]
